{
  "name": "@iptv/web-pc",
  "private": true,
  "version": "0.0.0",
  "description": "StreamPro IPTV - Premium IPTV client for Windows",
  "author": "Snarky Moose",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "server": "node server/server.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "start:desktop": "electron .",
    "build": "vite build",
    "build:exe": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.streampro.iptv",
    "productName": "StreamPro IPTV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "main.js",
      "package.json"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@noriginmedia/norigin-spatial-navigation": "^3.2.0",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "fuse.js": "^7.4.2",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "puppeteer": "^24.43.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.3",
    "electron": "41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
